{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voice Flow",
  "version": "0.1.0",
  "identifier": "dev.voiceflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Voice Flow",
        "width": 400,
        "height": 576,
        "minWidth": 360,
        "minHeight": 460,
        "center": true,
        "create": false,
        "visible": false,
        "resizable": true
      },
      {
        "label": "dictation",
        "title": "Voice Flow Dictation",
        "url": "index.html?window=dictation",
        "width": 720,
        "height": 72,
        "visible": false,
        "focus": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
